{
    "flake8.args": [
        "--max-line-length=100",
        "--exclude=venv,build,dist",
    ],
    "pylint.args": [
        "disable=W0178",
        "--max-line-length=100"
    ],
    "python.testing.unittestArgs": [
        "-v",
        "-s",
        ".",
        "-p",
        "test*.py"
    ],
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": true,
    "python.analysis.typeCheckingMode": "off",
    "python.analysis.autoImportCompletions": true,
}